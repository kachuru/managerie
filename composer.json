{
    "name": "kachuru/managerie",
    "description": "Library for multithreading scripts with signal control",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.3|>=8.4",
        "ext-pcntl": "*"
    },
    "require-dev": {
        "friends-of-phpspec/phpspec-code-coverage": "^7.0",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpspec/phpspec": "^8.2",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^3.13",
        "phpmd/phpmd": "^2.15"
    },
    "autoload": {
        "psr-4": {
            "Kachuru\\Thread\\": "src/Kachuru/Thread"
        }
    },
    "minimum-stability": "stable",
    "scripts": {
        "spec": [
            "vendor/bin/phpspec run"
        ],
        "coverage": [
            "phpdbg -qrr vendor/bin/phpspec -c phpspec-phpdbg.yml run"
        ],
        "sniff": [
            "vendor/bin/phpcs --standard=PSR2 --extensions=php src/"
        ],
        "fix": [
            "vendor/bin/phpcbf --standard=PSR2 --extensions=php src/"
        ],
        "stan": [
            "vendor/bin/phpstan analyse src/ --level max"
        ],
        "compatibility": [
            "vendor/bin/phpcs -s --standard=vendor/phpcompatibility/php-compatibility/PHPCompatibility/ --runtime-set testVersion 8.3- src/",
            "vendor/bin/phpcs -s --standard=vendor/phpcompatibility/php-compatibility/PHPCompatibility/ --runtime-set testVersion 8.4- src/"
        ],
        "test": [
            "@sniff",
            "@spec",
            "@stan",
            "@compatibility"
        ]
    }
}
